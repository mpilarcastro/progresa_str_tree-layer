# Read data
tree = read.table("tree_layer_str.csv", header=TRUE, sep=";")
table(tree$sp)
tree <- tree %>%
filter(sp == "Eucalyptus globulus") #only run to repeat analyses only with E. globulus
# PASO 1: Promediar los árboles a nivel de PLOT
# Conservamos 'veg_ty' para no perder la agrupación superior
medias_por_plot <- tree %>%
group_by(veg_ty, plot) %>%
summarise(
d_plot        = mean(d, na.rm = TRUE),
h_plot        = mean(h, na.rm = TRUE),
health_plot   = mean(health, na.rm = TRUE),
.groups = "drop"
)
# PASO 2: Calcular las medias finales y el Error Estándar (SE) real por VEG_TY
# Aquí tu N para el cálculo del SE será el número de plots (8), no de árboles.
tab_mean <- medias_por_plot %>%
group_by(veg_ty) %>%
summarise(
# Diámetro
d_media  = mean(d_plot, na.rm = TRUE),
d_se     = sd(d_plot, na.rm = TRUE) / sqrt(sum(!is.na(d_plot))),
# Altura
h_media  = mean(h_plot, na.rm = TRUE),
h_se     = sd(h_plot, na.rm = TRUE) / sqrt(sum(!is.na(h_plot))),
# Salud
health_media = mean(health_plot, na.rm = TRUE),
health_se    = sd(health_plot, na.rm = TRUE) / sqrt(sum(!is.na(health_plot))),
.groups = "drop"
)
rm(medias_por_plot)
