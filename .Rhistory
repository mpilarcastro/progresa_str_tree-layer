library(patchwork)
# 1. Combinamos los gráficos para que p1, p2 y p3 queden en la columna izquierda
panel_final <- (p1 + p4) /
(p2 + p5) /
(p3 + p6) +
plot_layout(ncol = 2, nrow = 3)
# 2. Guardamos con el tamaño exacto del póster (28x26 cm) y alta resolución
ggsave(
filename = "panel_6_graficos_poster.png",
plot = panel_final,
width = 28,
height = 26,
units = "cm",
dpi = 300
)
# Listamos los gráficos fila por fila:
# Fila 1: p1 (izq), p4 (der)
# Fila 2: p2 (izq), p5 (der)
# Fila 3: p3 (izq), p6 (der)
panel_final <- p1 + p4 + p2 + p5 + p3 + p6 +
plot_layout(ncol = 2, nrow = 3, byrow = TRUE)
# Guardamos con tus medidas exactas
ggsave(
filename = "panel_6_graficos_poster.png",
plot = panel_final,
width = 28,
height = 26,
units = "cm",
dpi = 300
)
