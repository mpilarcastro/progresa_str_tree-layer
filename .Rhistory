# 6. COMPARACIONES MÚLTIPLES POST-HOC (¿Qué bosque es diferente de cuál?)
# Esto te dará las comparaciones de parejas (Tukey) transformadas a la escala real de conteos
comparaciones <- emmeans(m_riq_quasi, poly ~ veg_ty, type = "response")
pairs(emmeans(m_riq_quasi, ~ veg_ty, type = "response"))
View(plot)
# 1. Ajustas el modelo lineal tradicional
m_shannon <- lm(Shannon ~ veg_ty, data = datos_plot)
# 2. comprobar residuos
residuos_shannon <- simulateResiduals(fittedModel = m_shannon)
plot(residuos_shannon)
# 3. Significación
anova(m_shannon)
# 4. Post-hoc
emm_shannon <- emmeans(m_shannon, ~ veg_ty)
emm_shannon
pairs(emm_shannon, adjust = "tukey")
m_gamma_disp <- glmmTMB(h ~ veg_ty + (1 | plot),
dispformula = ~ veg_ty,
data = tree,
family = Gamma(link = "log"))
# 3. Validación de Supuestos (Diagnóstico moderno)
# Elegimos el mejor modelo (supongamos que es m_gamma_disp) para validar
residuos_simulados <- simulateResiduals(fittedModel = m_gamma_disp)
# Este plot genera dos gráficos maravillosos:
# 1. Un QQ-plot ajustado para GLMMs (con tests estadísticos de normalidad integrados).
# 2. Un gráfico de residuos vs predicciones que evalúa la homocedasticidad con regresiones cuantílicas.
plot(residuos_simulados)
# Veo el resultado del modelo
Anova(m_gamma_disp, type = "III") #ojo, Anova con A mayúscula, paquete car
View(tree)
